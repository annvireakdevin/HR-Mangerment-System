PORT=5000
NODE_ENV=production

# Database — all required, no defaults
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hrms_db
DB_USER=hrms_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT — required, use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h

# Bcrypt rounds (10 minimum, 12 recommended for production)
BCRYPT_ROUNDS=12

# Frontend origin for CORS (required)
FRONTEND_URL=https://yourdomain.com
