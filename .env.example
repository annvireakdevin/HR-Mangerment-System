# Copy this file to .env and fill in all values before running docker-compose.
# Generate secrets with: openssl rand -hex 64

# Database
DB_NAME=hrms_db
DB_USER=hrms_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h

# Bcrypt rounds (12 recommended for production)
BCRYPT_ROUNDS=12

# CORS — must match the URL users access the app from
FRONTEND_URL=https://yourdomain.com
